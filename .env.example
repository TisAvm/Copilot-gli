# ═══════════════════════════════════════════════════════════
#  Copilot GLI — Environment Configuration
# ═══════════════════════════════════════════════════════════
#
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# Never commit .env to git — it's in .gitignore
#

# ── GitHub / Copilot (Zero Config) ──────────────────────────
# If you have gh CLI installed and authenticated (gh auth login),
# GLI auto-detects your token. No config needed!
#
# Only set this if you want to use a specific GitHub token
# instead of the auto-detected one from gh CLI:
# GITHUB_TOKEN=ghp_your_token_here

# ── Telegram Bot (Optional) ──────────────────────────────
# Create a bot via @BotFather on Telegram
# 1. Open Telegram, search for @BotFather
# 2. Send /newbot and follow prompts
# 3. Copy the bot token here
TELEGRAM_BOT_TOKEN=your-bot-token-here

# Group ID for broadcasting (optional)
# Add bot to group, then use https://api.telegram.org/bot<TOKEN>/getUpdates
# to find the group chat ID (negative number)
TELEGRAM_GROUP_ID=your-group-id-here

# ── Obsidian Vault (Optional) ────────────────────────────
# Path to your Obsidian vault for auto-recording
# All GLI activity will be logged under a GLI/ folder in your vault
# Windows: C:\Users\YourName\Documents\MyVault
# macOS:   /Users/YourName/Documents/MyVault
# Linux:   /home/yourname/Documents/MyVault
OBSIDIAN_VAULT_PATH=

# ── OpenRouter API (Optional) ────────────────────────────
# Only needed if you want 200+ models beyond GitHub Copilot's built-in ones
# Get your API key at https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Default model to use with OpenRouter (optional)
# See full list: https://openrouter.ai/models
OPENROUTER_DEFAULT_MODEL=anthropic/claude-sonnet-4-20250514
